# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# 虚拟环境
venv/
.venv/

# 环境变量(含数据库密码,绝不能提交)
.env

# 浏览器登录状态(含 cookies,绝不能提交)
storage_state*.json

# 爬虫产出/日志
*.log
data/*.csv
data/*.xlsx

# 临时排查/输出 txt(查库、清理、预览时写的中间产物,不该进 git)。
# requirements.txt 是依赖清单,必须提交,故不能用 *.txt 一刀切,逐个/按前缀忽略。
_*.txt
_*.csv
*_report.txt
*_result.txt
preview_*.txt
city_after.txt

# 断点续抓进度缓存(纯本地进度,删掉=从头抓,不该进 git)
.checkpoint_*.json

# IDE
.idea/
.vscode/

# 系统
*.DS_Store
Thumbs.db
